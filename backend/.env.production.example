# Mẫu .env cho PRODUCTION trên VPS.
# Copy thành backend/.env rồi điền giá trị thật:  cp .env.production.example .env

# --- Server ---
PORT=4000
# Domain frontend (dùng cho CORS). Cùng origin nên đặt đúng domain có https.
FRONTEND_URL=https://tenmien.com
# Dùng trong link ở email gửi cho khách / admin
SITE_URL=https://tenmien.com

# --- SQL Server (Docker chạy ở 127.0.0.1:1433) ---
MSSQL_SERVER=127.0.0.1
MSSQL_PORT=1433
MSSQL_DATABASE=glenns_plumbing
MSSQL_USER=sa
MSSQL_PASSWORD=Chuoi!Manh2024
MSSQL_ENCRYPT=false
MSSQL_TRUST_CERT=true

# --- Auth ---
# Tạo chuỗi ngẫu nhiên dài:  openssl rand -hex 32
JWT_SECRET=thay-bang-chuoi-ngau-nhien-dai

# --- SMTP (gửi email xác nhận lead) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Glenn's Plumbing <no-reply@tenmien.com>"

# --- Twilio (SMS báo admin — bỏ trống nếu chưa dùng) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
