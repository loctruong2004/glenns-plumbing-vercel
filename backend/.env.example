# ── Server ────────────────────────────────────────────────
# PORT chỉ dùng khi chạy local; trên Vercel platform tự quản cổng.
PORT=4000
# URL frontend được phép gọi API (CORS). Local: cổng Vite 5173.
FRONTEND_URL=http://localhost:5173
# URL site dùng trong link email (nút "Open Admin Dashboard"...).
SITE_URL=http://localhost:5173

# ── Supabase Postgres ─────────────────────────────────────
# Serverless (Vercel): dùng TRANSACTION POOLER (Supavisor), cổng 6543:
#   postgresql://postgres.[ref]:[password]@aws-[region].pooler.supabase.com:6543/postgres
# Local / seed-admin: có thể dùng DIRECT connection, cổng 5432:
#   postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-[region].pooler.supabase.com:6543/postgres
# Đặt PG_SSL=false nếu chạy Postgres local KHÔNG bật SSL (Supabase luôn cần SSL).
# PG_SSL=true

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET=thay-bang-chuoi-ngau-nhien-dai

# ── SMTP (Resend) ─────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxxxxxx
SMTP_FROM="Glenn's Plumbing NYC <no-reply@your-domain.com>"
SMTP_REPLY_TO=

# ── Twilio (tuỳ chọn — để trống nếu không gửi SMS) ─────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
